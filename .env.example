# --- FAZ 1: YAPAY ZEKA ---
# OpenAI veya alternatif sağlayıcı anahtarı
OPENAI_API_KEY=your_openai_api_key_here

# --- FAZ 2: VERİTABANI & GİRİŞ (SUPABASE) ---
# Supabase Proje URL'si
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
# Supabase Anon (Public) Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- FAZ 3: ÖDEME DUVARI (STRIPE / SHOPIER) ---
# Stripe Public Key (Frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_public_key_here
# Stripe Secret Key (Backend)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Stripe Webhook Secret (Gerçek zamanlı ödeme onayı için)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Shopier API Key & Secret
SHOPIER_API_KEY=your_shopier_api_key_here
SHOPIER_API_SECRET=your_shopier_api_secret_here
# Shopier Product Pages
NEXT_PUBLIC_SHOPIER_BOOK_URL=your_shopier_book_url_here
NEXT_PUBLIC_SHOPIER_SECRET_FILES_URL=your_shopier_secret_files_url_here
